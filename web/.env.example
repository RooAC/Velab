# Backend proxy target used by Next.js API routes
BACKEND_URL=http://localhost:8000

# Production auth gate.
# Keep false locally. In production set both WEB_AUTH_ENABLED and NEXT_PUBLIC_WEB_AUTH_ENABLED to true.
WEB_AUTH_ENABLED=false
NEXT_PUBLIC_WEB_AUTH_ENABLED=false

# Password accepted by /api/auth/login when WEB_AUTH_ENABLED=true.
# Use a strong random value in production.
# AUTH_LOGIN_PASSWORD=

# Optional cookie signing secret. If omitted, AUTH_LOGIN_PASSWORD is used.
# AUTH_SESSION_SECRET=

# Backend API key forwarded server-side by Next.js proxy routes.
# Must match backend AUTH_API_KEY when backend AUTH_ENABLED=true.
# BACKEND_API_KEY=

# Hide demo scenario switcher in production if desired.
NEXT_PUBLIC_SHOW_SCENARIO_SWITCHER=true
